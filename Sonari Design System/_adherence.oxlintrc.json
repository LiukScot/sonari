{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/sound/**",
              "ui_kits/sonari-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|accent|gradient|success|outline)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'accent' | 'gradient' | 'success' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|full|disabled|children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, full, disabled, children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|tone|active|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, tone, active, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|raised)$/]",
        "message": "<IconButton> tone must be one of 'default' | 'raised'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:playing|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PlayButton> doesn't accept that prop. Declared props: playing, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|sub|icon|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<QuickTile> doesn't accept that prop. Declared props: label, sub, icon, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SoundCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|icon|volume|active|onToggle|onVolume|style|key|ref|className|style|children)$/]",
        "message": "<SoundCard> doesn't accept that prop. Declared props: name, icon, volume, active, onToggle, onVolume, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VolumeSlider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|icon|active|label|onChange|style|key|ref|className|style|children)$/]",
        "message": "<VolumeSlider> doesn't accept that prop. Declared props: value, icon, active, label, onChange, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
